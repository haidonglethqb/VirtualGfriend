# Server Configuration
NODE_ENV=development
PORT=3001

# Database
# For production, add connection pool settings for better performance:
# DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public&connection_limit=20&pool_timeout=30"
DATABASE_URL="postgresql://vgfriend:vgfriend123@localhost:5432/vgfriend?schema=public"

# Redis (optional — app works without it, but caching disabled)
REDIS_URL="redis://localhost:6379"

# JWT Secrets
JWT_SECRET=your-super-secret-access-key-change-in-production
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI - Choose one: OpenAI, Gemini, or Groq (recommended - free)
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
AI_PROVIDER=groq

# Google Drive Storage (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# CORS
CORS_ORIGIN=http://localhost:3000

# Email Configuration (for password reset OTP)
# For Gmail: Create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_NAME=VGfriend

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Admin Panel
# Generate a password hash with: node -e "require('bcryptjs').hash('your-strong-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=your-bcrypt-hashed-admin-password
# Generate a secret with: openssl rand -base64 32
ADMIN_JWT_SECRET=your-admin-jwt-secret-at-least-32-characters-long
