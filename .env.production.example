# ===========================================
# Production Environment Variables
# Copy this to .env on your VPS
# ===========================================

# Database
POSTGRES_USER=vgfriend
POSTGRES_PASSWORD=your-very-strong-db-password-here
POSTGRES_DB=vgfriend

# JWT Secrets - Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-different-from-jwt-secret

# AI Provider - Groq is free and fast
GROQ_API_KEY=your-groq-api-key


# CORS - Your frontend domain
CORS_ORIGIN=https://yourdomain.com

# Frontend URLs - Point to your API domain
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=https://api.yourdomain.com

# GitHub Container Registry
GITHUB_REPOSITORY=your-username/VirtualGfriend

# Admin Panel - Generate with: node -e "require('bcryptjs').hash('your-strong-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=your-bcrypt-hashed-admin-password
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=your-admin-jwt-secret-at-least-32-characters-long
