{
  "name": "@vgfriend/e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for VGfriend using Playwright with POM pattern",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:api": "playwright test --project=api --workers=1",
    "test:ui-tests": "playwright test tests/ui",
    "test:auth": "playwright test tests/ui/auth",
    "test:chat": "playwright test tests/ui/chat",
    "test:dashboard": "playwright test tests/ui/dashboard",
    "test:headless": "playwright test --project=chromium",
    "test:chrome": "playwright test --project=chromium --headed",
    "test:firefox": "playwright test --project=firefox --headed",
    "test:webkit": "playwright test --project=webkit --headed",
    "test:all-browsers": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:3000",
    "install-browsers": "playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3",
    "dotenv": "^16.4.1"
  },
  "author": "VGfriend Team",
  "license": "MIT"
}
